{
  "hooks": {
    "PreToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/dos-hook\" pretool --workspace . || python -m dos.cli hook pretool --workspace ."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Read|Bash|Grep|Glob",
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/dos-hook\" posttool --workspace . || python -m dos.cli hook posttool --workspace ."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/bin/dos-hook\" stop --workspace . || python -m dos.cli hook stop --workspace ."
          }
        ]
      }
    ]
  }
}
