{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "shell": "bash",
            "command": "dos hook stop --workspace . || python -m dos.cli hook stop --workspace ."
          }
        ]
      }
    ]
  },
  "permissions": {
    "allow": [
      "Bash(python scripts/trajectory_audit.py:*)",
      "Bash(python scripts/git_hygiene.py:*)"
    ]
  }
}
