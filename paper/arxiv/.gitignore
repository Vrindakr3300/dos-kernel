# Build scratch from make_bundle.py: the staged tree and the cleaner's output.
# Both are regenerated on every run (the tarball in releases/ is the durable
# artifact, tracked the same way paper/releases/paper-*.pdf is).
_bundle/
_bundle_arXiv/

# A locally-compiled bibliography/aux: present only if you ran pdflatex+bibtex
# here (or dropped Overleaf's main.bbl in to ship it). main.bbl is COPIED into
# the bundle when present, but the loose copy next to main.tex is a build product,
# not source — refs.bib (the SOURCE) is generated by assemble_arxiv.py and tracked.
main.bbl
main.aux
main.log
main.out
main.blg
main.pdf
